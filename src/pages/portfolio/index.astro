---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import BaseLayout from "@/layouts/BaseLayout.astro";
import SeoPage from "@/components/SeoPage.astro";

const projects = (await getCollection("portfolio")).sort(
  (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
---

<BaseLayout>
  <SeoPage slot="head" title="Portfolio" description="Selected work by Ethan Palm." />
  <section class="py-3">
    <h1 class="text-[36px] leading-snug font-bold text-black dark:text-white mb-12">
      Portfolio
    </h1>
    <div class="grid gap-12">
      {
        projects.map((project) => (
          <a
            href={`/portfolio/${project.id}`}
            class="group block"
          >
            {project.data.image && (
              <Image
                src={project.data.image}
                alt={project.data.imageAlt || ""}
                class="mb-4 h-auto w-full"
                draggable="false"
              />
            )}
            <h2 class="text-xl font-bold text-black dark:text-white group-hover:underline">
              {project.data.title}
            </h2>
            <p class="text-muted-text dark:text-dark-muted-text mt-1">
              {project.data.description}
            </p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
